{
    "name": "dndark/laravel-logic-map",
    "description": "Evidence-backed Laravel semantic workflows, dependency impact analysis, and interactive logic maps.",
    "keywords": [
        "laravel",
        "semantic-analysis",
        "change-impact",
        "workflow",
        "architecture",
        "static-analysis",
        "graph",
        "visualization",
        "code-intelligence"
    ],
    "homepage": "https://github.com/DNDark12/laravel-logic-map",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "DNDark"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.5",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "DNDark\\LogicMap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DNDark\\LogicMap\\Tests\\": "tests/"
        },
        "exclude-from-classmap": [
            "/tests/Fixtures/"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:feature": "phpunit --testsuite=Feature"
    },
    "extra": {
        "laravel": {
            "providers": [
                "DNDark\\LogicMap\\LogicMapServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
